{
  "name": "@primitive/cli",
  "version": "0.1.0-beta.1",
  "description": "CLI for managing Primitive specs, contexts, and git hooks",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/primitive-dev/cli.git"
  },
  "homepage": "https://github.com/primitive-dev/cli#readme",
  "bugs": {
    "url": "https://github.com/primitive-dev/cli/issues"
  },
  "keywords": [
    "primitive",
    "prim",
    "cli",
    "specs",
    "contexts",
    "pre-commit"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "bin": {
    "prim": "./dist/index.js",
    "prim-pre-commit": "./dist/hooks/pre-commit.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/hooks/pre-commit.ts --format esm --clean",
    "postbuild": "chmod +x ./dist/index.js ./dist/hooks/pre-commit.js",
    "dev": "tsup src/index.ts src/hooks/pre-commit.ts --format esm --watch --clean",
    "clean": "rm -rf dist coverage",
    "lint": "biome check src/",
    "format": "biome check --fix src/",
    "format:check": "biome check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.1.0"
  }
}
